# AI Mixer Pro - Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# APPLICATION
# ===========================================
NODE_ENV=production
APP_URL=https://aimixer.pro
APP_NAME=AI Mixer Pro

# ===========================================
# DATABASE
# ===========================================
DATABASE_URL=postgresql://user:password@localhost:5432/aimixer
DATABASE_POOL_SIZE=10

# ===========================================
# REDIS
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===========================================
# AUTHENTICATION (Clerk)
# ===========================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ===========================================
# FILE STORAGE (AWS S3)
# ===========================================
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=ai-mixer-pro
AWS_S3_ENDPOINT=

# ===========================================
# STRIPE PAYMENTS
# ===========================================
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx

# ===========================================
# AI PROCESSING
# ===========================================
AI_PROCESSING_CONCURRENCY=5
AI_TIMEOUT_MINUTES=30

# ===========================================
# RATE LIMITING
# ===========================================
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_FREE_MAX=100
RATE_LIMIT_PRO_MAX=1000
RATE_LIMIT_STUDIO_MAX=5000

# ===========================================
# MONITORING
# ===========================================
PROMETHEUS_ENABLED=true
LOG_LEVEL=info

# ===========================================
# ADMIN
# ===========================================
ADMIN_USER_IDS=user_id_1,user_id_2

# ===========================================
# CACHE
# ===========================================
CACHE_TTL_DAYS=7
CACHE_MAX_SIZE_MB=1000
