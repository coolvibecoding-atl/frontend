// Prisma Schema for AI Mixer Pro
// Using SQLite-compatible types

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  firstName     String?
  lastName      String?
  imageUrl      String?
  role          String   @default("USER")
  stripeCustomerId String?
  subscription  Subscription[]
  tracks        Track[]  @relation("UserTracks")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([email])
}

model Subscription {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  stripeSubscriptionId String
  stripePriceId String
  stripeCurrentPeriodEnd DateTime
  status        String   // active, canceled, past_due, unpaid
  plan          String   @default("FREE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([stripeSubscriptionId])
  @@index([userId])
}

model Track {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation("UserTracks", fields: [userId], references: [id])
  name          String
  filename      String   // original filename
  storedFilename String   // the actual filename stored on disk
  fileSize      Int      // in bytes
  fileType      String   // mime type
  status        String   @default("UPLOADED")
  progress      Int      @default(0) // 0-100
  duration      Float?   // in seconds
  waveformData  String?  // stored waveform data for visualization (stored as JSON string)
  stemCount     Int      @default(0)
  processedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  processingLogs ProcessingLog[] @relation("TrackProcessingLogs")
  shareLinks    ShareLink[]    @relation("TrackShareLinks")
  jobs          Job[]      @relation("TrackJobs")

  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@index([createdAt])
}

model ProcessingLog {
  id            String   @id @default(cuid())
  trackId       String
  track         Track    @relation("TrackProcessingLogs", fields: [trackId], references: [id])
  step          String   // e.g., "STEM_SEPARATION", "MIXING", "MASTERING"
  status        String   // started, completed, failed
  message       String?
  progress      Int      @default(0)
  startedAt     DateTime @default(now())
  completedAt   DateTime?
}

model Job {
  id            String   @id @default(cuid())
  trackId       String
  track         Track    @relation("TrackJobs", fields: [trackId], references: [id])
  status        String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  progress      Int      @default(0) // 0-100
  step          String?  // Current processing step
  error         String?  // Error message if failed
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([trackId])
  @@index([status])
  @@index([status, createdAt])
}

model ShareLink {
  id            String   @id @default(cuid())
  trackId       String
  track         Track    @relation("TrackShareLinks", fields: [trackId], references: [id])
  token         String   @unique
  expiresAt     DateTime
  maxDownloads  Int?
  downloadCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([trackId])
  @@index([token])
}
